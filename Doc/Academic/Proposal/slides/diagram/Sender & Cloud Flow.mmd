flowchart TB
    %% --- STYLE DEFINITIONS ---
    classDef mobile fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#000
    classDef decision fill:#fff9c4,stroke:#fbc02d,stroke-width:2px,color:#000
    classDef warning fill:#ffccbc,stroke:#ff5722,stroke-width:2px,color:#000
    classDef danger fill:#ffcdd2,stroke:#c62828,stroke-width:2px,color:#000

    Start(["User Opens Chat"]) --> A["Select Contact"]
    A --> B["Fetch Contact Public Key"]
    B --> C["User Types Message"]
    C --> D["AI Pre-Scan: Tokenize Text"]
    D --> E["AI Feature Extraction"]
    E --> F["TFLite Model Inference"]
    F --> G{"Threat Score Result"}
    
    G -- "Safe" --> H["Proceed to Encryption"]
    G -- "Suspicious" --> I["Show Orange Warning"]
    I --> J{"User Confirm Send?"}
    J -- Yes --> H
    J -- No --> K["Return to Edit"]
    K --> C
    G -- "Threat" --> L["Show Red Alert Block"]
    L --> K
    
    H --> M["Generate Ephemeral Key"]
    M --> N["ECDH Key Exchange"]
    N --> O["Derive Shared Secret"]
    O --> P["Encrypt AES-256-GCM"]
    P --> Q{"Has Media Files?"}
    Q -- No --> R["Create Text Payload"]
    Q -- Yes --> S["Encrypt Media"]
    S --> T["Upload to Firebase"]
    T --> U["Generate Temp URL"]
    U --> R
    R --> V["Send to Backend"]
    V --> W["Store in Firestore"]

    %% --- APPLY CLASSES ---
    class Start,A,B,C,D,E,F,H,M,N,O,P,R,S,T,U,V,W,X,Y,Z mobile
    class G,J,Q decision
    class I warning
    class L danger