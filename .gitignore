# =========================================
# 🧠 SentriZK Unified .gitignore
# Covers Node.js backend + Flutter mobile + docs
# =========================================

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Flutter / Dart ---
**/build/
**/.dart_tool/
**/.packages
**/pubspec.lock
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.metadata
**/ios/Flutter/Flutter.framework/
**/ios/Flutter/Flutter.podspec
**/ios/.symlinks/
**/ios/Pods/
**/ios/Runner.xcworkspace/
**/android/.gradle/
**/android/app/build/
**/android/local.properties
**/android/key.properties

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# --- VS Code / IDE ---
.vscode/
.idea/
*.iml

# --- Logs & Temp ---
*.log
*.tmp
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Tests / Coverage ---
coverage/
test-results/

# --- Build Artifacts ---
dist/
out/
*.exe
*.dll
*.so
*.dylib
*.pyc
*.pyo
*.pyd
*.class
*.jar

# --- Docs / Misc ---
docs/*.tmp
*.bak
*.orig

# --- Git ---
.gitignore
