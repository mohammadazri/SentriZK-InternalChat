# =========================================
# 🧠 SentriZK Unified .gitignore
# Covers Node.js backend + Flutter mobile + docs + binaries
# =========================================
#ignore daatset in ML projects
ML/dataSet/

#ignore tflite & model files
ML/models/*.tflite
ML/models/*.h5
ML/models/*.pb
ML/models/*.ckpt
ML/models/*.joblib

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-debug.log*
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
serviceAccountKey.json

# --- Flutter / Dart ---
**/build/
**/.dart_tool/
**/.packages
**/pubspec.lock
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.metadata
