# =====================================
# 📱 SentriApp Mobile Configuration
# =====================================

# Backend API URL (for testing)
# Change this in Frontend/mobile/lib/config/app_config.dart
API_URL=https://backend.your-domain.shop

# Web Frontend URL (for login/registration bridge)
# Change this in Frontend/mobile/lib/config/app_config.dart
WEB_URL=https://web.your-domain.shop

# Deep Link Scheme
DEEP_LINK_SCHEME=sentriapp

# Google Safe Browsing API key (do not commit real values)
SAFE_BROWSING_API_KEY=YOUR_GOOGLE_SAFE_BROWSING_API_KEY
# =====================================
