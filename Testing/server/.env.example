# ── SentriZK Test Runner — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real keys.

# ── Backend ──────────────────────────────────────────────────────────
BACKEND_URL=https://backend.sentrizk.me
PORT=3001

# ── Supabase (Service Role Key — gives full DB read access for C1 test)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1Ni...your.service.role.key

# ── Firebase (Path to serviceAccountKey.json from the Backend folder)
FIREBASE_SERVICE_ACCOUNT_PATH=../../Backend/serviceAccountKey.json

# ── Test Account (Register via web frontend first, then record here)
TEST_USER=sentrizk_test_user
TEST_SECRET=            # 256-bit bigint string (your ZKP secret)
TEST_SALT=              # 128-bit bigint string
TEST_UNAME_HASH=        # keccak256("sentrizk_test_user") as bigint string
TEST_DEVICE=test_device_dashboard_001

# ── Admin credentials (for admin endpoint tests)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# ── ZKP Circuit files (relative to server/ directory)
LOGIN_WASM=../../Backend/circuits/login/login.wasm
LOGIN_ZKEY=../../Backend/circuits/key_generation/login_final.zkey

# ── APK path (build first: flutter build apk --release)
APK_PATH=../../Frontend/mobile/build/app/outputs/flutter-apk/app-release.apk

# ── ML assets paths
ML_MODEL_PATH=../../Frontend/mobile/assets/ml/sentrizk_model.tflite
ML_VOCAB_PATH=../../Frontend/mobile/assets/ml/vocab.json
ML_SERVICE_PATH=../../Frontend/mobile/lib/services/message_scan_service.dart
